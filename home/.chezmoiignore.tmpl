# feature-based ignores
{{ if .headless }}
.config/Xresources
.config/alacritty
.config/ghostty
.config/i3
.config/xinit
{{ end }}
{{ if .transient }}
.chezmoiscripts/packages/*
.local/share/mise
.ssh/authorized_keys
.ssh/known_hosts
{{ end }}

# os-based ignores
{{ if ne .chezmoi.os "windows" }} # ignore windows files on *nix
.chezmoiscripts/*.ps1
AppData
bin
Documents
{{ else }} # ignore *nix files on windows
.chezmoiscripts/*.sh
.config/*
!.config/git # ...except git, which stores config files at the same paths
.local
.ssh/config.d/multiplexing
{{ end }}

{{ if eq .chezmoi.os "darwin" }} # ignore x11 files on macos
.config/Xresources
.config/i3
.config/xinit
{{ else }} # macos-only software
.config/brew
.config/fish/functions.d/utils/bcd.fish
.config/fish/functions.d/utils/dash.fish
.local/share/terminfo # terminfo hacks are only needed on macos
{{ end }}

{{ if ne .chezmoi.os "freebsd" }} # freebsd-only software
.config/fish/functions.d/utils/portfind.fish
{{ end }}

{{ if hasPrefix "linux-arch" .osid }} # hushlogin on everything but arch
.hushlogin
{{ end }}
