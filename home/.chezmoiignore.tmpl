# feature-based ignores
{{ if .headless }}
.config/Xresources
.config/xinit
.config/alacritty
.config/ghostty
.config/i3
{{ end }}
{{ if .transient }}
.chezmoiscripts/packages/*
.config/mise
.ssh/authorized_keys
.ssh/known_hosts
{{ end }}

# os-based ignores
{{ if ne .chezmoi.os "windows" }} # ignore windows files on *nix
.chezmoiscripts/*.ps1
AppData
bin
Documents
{{ else }} # ignore *nix files on windows
.chezmoiscripts/*.sh
.config/*
!.config/git # ...except git, which stores config files at the same paths
.local
.ssh/config.d/multiplexing
.hushlogin
{{ end }}

{{ if eq .chezmoi.os "darwin" }} # ignore x11 files on macos
.config/Xresources
.config/xinit
.config/handlr
.config/mimeapps.list
.config/i3
{{ else }} # macos-only software
.config/homebrew
.local/share/terminfo
{{ end }}

{{ if eq .chezmoi.os "linux" }}
{{   if eq .chezmoi.osRelease.id "arch" }} # not used on arch
.hushlogin
{{   else }} # only used on arch
.config/pacman
.config/paru
{{   end }}
{{ else }} # only used on linux
.config/electron-flags.conf
.config/spotify-flags.conf
.config/pacman
.config/paru
.config/systemd
.local/share/dbus-1
{{ end }}

{{ if eq .chezmoi.os "freebsd" }} # not used on freebsd
.config/mise
{{ end }}
