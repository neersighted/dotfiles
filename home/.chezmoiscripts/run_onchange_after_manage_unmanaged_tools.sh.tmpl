#!/bin/sh -e

cd "${XDG_BIN_HOME:-$HOME/.local/bin}"

if [ -f "./chezmoi" ] && [ "$(which -a chezmoi | wc -l)" -gt 1 ]; then
  echo "Switching to system-managed chezmoi..."
  rm -f "./chezmoi"
fi
{{ if lookPath "go" }}
echo "Installing Go tools..."
{{ range .tools.go -}}
command -v {{ base . }} >/dev/null || go install {{ . }}@latest
{{ end -}}
{{ end }}
{{- if lookPath "cargo" }}
echo "Installing Rust crates..."
cargo_wanted="{{ range .tools.cargo }}{{ . }} {{ end }}{{ if eq .chezmoi.os "linux" }}{{ range .tools.linux.cargo }}{{ . }} {{ end }}{{ end }}"
cargo_installed="$(cargo install --list | awk '/^[^[:space:]]/ { print $1 }')"
cargo_missing=""
for crate in $cargo_wanted; do
  printf '%s\n' "$cargo_installed" | grep -qx "$crate" || cargo_missing="$cargo_missing $crate"
done
# shellcheck disable=SC2086 # intentional split: one arg per crate
[ -z "$cargo_missing" ] || cargo install --locked --force -- $cargo_missing
{{ end }}
{{- if lookPath "pipx" }}
echo "Installing Python apps..."
pipx_installed="$(pipx list --json | jq -r '.venvs[].metadata.main_package.package')"
{{ range .tools.python -}}
printf '%s\n' "$pipx_installed" | grep -qx "{{ . }}" || pipx install "{{ . }}"
{{ end -}}
{{ end }}
