{{- if eq .chezmoi.os "freebsd" -}}
#!/bin/sh -eu
{{- $packages := list }}
{{- range .packages -}}
{{-   $name := "" -}}
{{-   if kindIs "string" . -}}
{{-     $name = . -}}
{{-   else if hasKey . "freebsd" -}}
{{-     $name = .freebsd -}}
{{-   end -}}
{{-   if $name -}}
{{-     $packages = append $packages $name -}}
{{-   end -}}
{{- end }}

if [ "$(id -u)" -ne 0 ]; then
  echo "Asking for root credentials..."
  exec su root -c "sh $0"
fi

echo "Installing packages with pkg..."
pkg install -y {{ $packages | sortAlpha | uniq | join " " }}

# Set up pkg-provides.
if ! grep -Eq '^PKG_ENABLE_PLUGINS' /usr/local/etc/pkg.conf; then
  sed -e '/PKG_PLUGINS_DIR/s/^#//' -e '/PKG_ENABLE_PLUGINS/s/^#//' \
    -e 's/#PLUGINS \[/PLUGINS [ provides ]/' -i '' /usr/local/etc/pkg.conf
fi

{{- end -}}
