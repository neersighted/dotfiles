{{- if eq .chezmoi.os "linux" -}}
{{- if eq .chezmoi.osRelease.id "arch" -}}
#!/bin/sh -eu
{{- $repo := list }}
{{- $aur := list -}}
{{- range .packages -}}
{{-   $name := "" -}}
{{-   $isAur := false -}}
{{-   if kindIs "string" . -}}
{{-     $name = . -}}
{{-   else if hasKey . "arch" -}}
{{-     $a := .arch -}}
{{-     if kindIs "string" $a -}}
{{-       $name = $a -}}
{{-     else -}}
{{-       $name = $a.name -}}
{{-       if hasKey $a "aur" -}}{{- $isAur = $a.aur -}}{{- end -}}
{{-     end -}}
{{-   end -}}
{{-   if $name -}}
{{-     if $isAur -}}
{{-       $aur = append $aur $name -}}
{{-     else -}}
{{-       $repo = append $repo $name -}}
{{-     end -}}
{{-   end -}}
{{- end }}

echo "Installing repo packages with pacman..."
sudo pacman -S --needed {{ $repo | sortAlpha | uniq | join " " }}

if ! command -v paru >/dev/null; then
  echo "Bootstrapping paru..."

  paru=$(mktemp -d)
  trap 'rm -rf "$paru"' EXIT

  git clone https://aur.archlinux.org/paru.git "$paru"
  OPTIONS='!debug' makepkg -D "$paru" --syncdeps --rmdeps --install

  GNUPGHOME=$(mktemp -d)
  trap 'rm -rf "$GNUPGHOME"' EXIT
  export GNUPGHOME
fi

echo "Installing AUR packages with paru..."
paru -S --needed --aur {{ $aur | sortAlpha | uniq | join " " }}

# Set up the Pacman filesdb.
echo "Updating pacman filesdb..."
sudo pacman -Fy
systemctl is-enabled --quiet pacman-filesdb-refresh.timer || sudo systemctl enable --now pacman-filesdb-refresh.timer

{{- end -}}
{{- end -}}
