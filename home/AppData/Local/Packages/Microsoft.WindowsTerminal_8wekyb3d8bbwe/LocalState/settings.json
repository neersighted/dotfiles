{
    "$help": "https://aka.ms/terminal-documentation",
    "$schema": "https://aka.ms/terminal-profiles-schema",

    "theme": "mica",
    "themes": [
        {
            "name": "mica",
            "window": {
                "applicationTheme": "system",
                "useMica": true
            },
            "tab": {
                "background": "terminalBackground",
                "unfocusedBackground": "#00000000",
                "showCloseButton": "hover"
            },
            "tabRow": {
                "background": "#00000000",
                "unfocusedBackground": "#00000000"
            }
        }
    ],

    "schemes": [],

    "defaultProfile": "{7bee06fb-f91d-5dfe-96fb-74145f815991}",
    "disabledProfileSources": 
    [
        "Windows.Terminal.Azure",
        "Windows.Terminal.VisualStudio",
        "Windows.Terminal.Wsl" // Legacy WSL profile source
    ],
    "profiles": 
    {
        "defaults": 
        {
            "environment":
            {
                "TERM": "ms-terminal-direct",
                "COLORTERM": "truecolor"
            },
            "padding": "2",
            "cursorShape": "filledBox",
            "font": 
            {
                "face": "Source Code Pro",
                "size": 11
            },
            "antialiasingMode": "cleartype",
            "intenseTextStyle": "bold",
            "showMarksOnScrollbar": true,
            "closeOnExit": "graceful"
        },
        "list": 
        [
            {
                "name": "Arch",
                "guid": "{7bee06fb-f91d-5dfe-96fb-74145f815991}",
                "source": "Microsoft.WSL",
                "scrollbarState": "hidden"
            },
            {
                "name": "PowerShell",
                "guid": "{574e775e-4f2a-5b96-ac1e-a2962a402336}",
                "source": "Windows.Terminal.PowershellCore",
                "colorScheme": "One Half Dark"
            },
            {
                "name": "Windows PowerShell",
                "guid": "{61c54bbd-c2c6-5271-96e7-009a87ff44bf}",
                "colorScheme": "Campbell Powershell"
            },
            {
                "name": "Command Prompt",
                "guid": "{0caa0dad-35be-5f56-a8ff-afceeeaa6101}",
                "colorScheme": "Campbell"
            },
            {
                "name": "Git Bash",
                "guid": "{2ece5bfe-50ed-5f3a-ab87-5cd4baafed2b}",
                "source": "Git",
                "colorScheme": "Vintage"
            }
        ]
    },

    "newTabMenu": 
    [
        {
            "source": "^(Microsoft|Windows.Terminal)\\.WSL$",
            "type": "matchProfiles"
        },
        { "type": "separator" },
        {
            "name": "(Windows )?PowerShell",
            "type": "matchProfiles"
        },
        { "type": "separator" },
        {
            "type": "remainingProfiles"
        }
    ],

    "keybindings": 
    [
        {
            "id": null, // Defaults to fullscreen
            "keys": "alt+enter"
        }
    ]
}
// vi: ft=jsonc
