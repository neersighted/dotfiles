#!/usr/bin/env fish

if not command -q rustup
  set_color red
  echo "Installing rustup..."
  set_color normal

  curl -sSf https://sh.rustup.rs | sh -s -- -y --no-modify-path --default-toolchain none
  set -p PATH $CARGO_HOME/bin
else
  set_color red
  echo "Updating rustup..."
  set_color normal

  rustup self update
end

for toolchain in stable nightly
  set_color red
  echo "Installing/updating $toolchain Rust toolchain..."
  set_color normal

  rustup toolchain install \
    --no-self-update \
    --component rust-analyzer \
    --component rust-src \
    $toolchain
end

# Crates are installed declaratively from [tools].cargo by
# run_onchange_after_manage_unmanaged_tools; this script only updates them.
# cargo-install-update (from the cargo-update crate) may not be present until
# that runs, so gate on it.
if command -q cargo-install-update
  set_color red
  echo "Updating crates..."
  set_color normal

  cargo install-update --all
end
