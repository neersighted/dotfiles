#!/usr/bin/env fish

if not command -q rustup
  set_color red
  echo "Installing rustup..."
  set_color normal

  curl -sSf https://sh.rustup.rs | sh -s -- -y --no-modify-path --default-toolchain none
  set -p PATH $CARGO_HOME/bin
else
  set_color red
  echo "Updating rustup..."
  set_color normal

  rustup self update
end

for toolchain in stable nightly
  set_color red
  echo "Installing/updating $toolchain Rust toolchain..."
  set_color normal

  rustup toolchain install \
    --no-self-update \
    --component rust-analyzer \
    --component rust-src \
    $toolchain
end

set wanted \
   cargo-audit \
   cargo-asm \
   cargo-binutils \
   cargo-bloat \
   cargo-depgraph \
   cargo-edit \
   cargo-expand \
   cargo-feature \
   cargo-fuzz \
   cargo-release \
   cargo-sort \
   cargo-supply-chain \
   cargo-outdated \
   cargo-udeps \
   cargo-update \
   cargo-watch \
   flamegraph

if is_linux
  set -a wanted \
     cargo-tarpaulin \
     cross
end

set installed (cargo install --list | string match -r '^\S+')
set missing
for crate in $wanted
  contains -- $crate $installed; or set -a missing $crate
end

if test (count $missing) -gt 0
  set_color red
  echo "Installing crates..."
  set_color normal

  cargo install --locked --force -- $missing
end

set_color red
echo "Updating crates..."
set_color normal

cargo install-update --all
