#!/usr/bin/env fish

set_color yellow
echo "Updating pyenv..."
set_color normal

for repo in $PYENV_ROOT $PYENV_ROOT/plugins/*
  git -C $repo pull -q
end

set release_cycle (curl -sSf https://peps.python.org/api/release-cycle.json)
or begin
  set_color red
  echo "pyenv-update: could not fetch the Python release cycle" >&2
  set_color normal
  exit 1
end
set releases (printf '%s' $release_cycle | yq -ojson -I0)

for release in (printf '%s' $releases | yq -r 'to_entries[] | select(.value.status | contains("bugfix", "security")) | .key')
  set latest (pyenv latest --known $release)
  set installed (pyenv latest $release)

  if test "$installed" != "$latest"
    set_color yellow
    echo "Installing latest Python $release..."
    set_color normal

    pyenv install $release
  end
end

set wanted \
   pip-run \
   pip-tools \
   poetry \
   shiv

set installed (pipx list --json | yq '.venvs[].metadata.main_package | [.package, .suffix] | join("")')
set missing
for spec in $wanted
  contains -- $spec $installed; or set -a missing $spec
end

if test (count $missing) -gt 0
  set_color yellow
  echo "Installing Python development apps..."
  set_color normal

  for spec in $missing
    pipx install "$spec"
  end
end

if test (count $installed) -gt 0
  set_color yellow
  echo "Updating pipx apps..."
  set_color normal

  # specs -> apps
  for app in (string match -r '^[^[]*' $installed)
    pipx upgrade --include-injected "$app"
  end
end

set_color yellow
echo "Updating system packages..."
set_color normal

function pip
  PIP_REQUIRE_VIRTUALENV= command pyenv exec python -m pip --disable-pip-version-check $argv
end

for python in (pyenv versions --bare --skip-aliases)
  set -lx PYENV_VERSION $python

  for spec in (pip list --outdated --format=json | yq -ojson -I0 '.[]')
    set name (printf '%s' $spec | yq '.name')
    set current (printf '%s' $spec | yq '.version')
    set latest (printf '%s' $spec | yq '.latest_version')

    set_color yellow
    echo "Updating $name from $current to $latest ($python)..."
    set_color normal

    pip install -U $name
  end
end
