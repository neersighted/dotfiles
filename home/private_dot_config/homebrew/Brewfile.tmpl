{{- $formulae := .packages.macos.formulae | default list -}}
{{- $services := .packages.macos.services | default list -}}
{{- $casks := .packages.macos.casks | default list -}}
{{- $noShaCasks := .packages.macos.no_sha.casks | default list -}}
{{- $trustedTaps := .packages.macos.taps | default list -}}
{{- $implicitTaps := list -}}
{{- range (concat $formulae $casks) -}}
{{- if contains "/" . -}}
{{- $implicitTaps = append $implicitTaps (slice (splitList "/" .) 0 2 | join "/") -}}
{{- end -}}
{{- end -}}
{{- range $noShaCasks -}}
{{- if contains "/" . -}}
{{- fail (printf "no_sha cask %q is non-official; all non-official casks must be require_sha: true" .) -}}
{{- end -}}
{{- end -}}
{{- range $services -}}
{{- if not (has . $formulae) -}}
{{- fail (printf "service %q is not a declared formula; brew services is formula-only" .) -}}
{{- end -}}
{{- end -}}
# .packages.macos.taps: all contents trusted
# .packages.macos.formulae, .packages.macos.casks:
#   - official: implicitly trusted
#   - non-official: narrowly trusted
# .packages.macos.no_sha.casks:
#   - official: require_sha skipped
#   - non-official: blocked
{{ range (concat $trustedTaps $implicitTaps) | sortAlpha | uniq -}}
tap {{ quote . }}{{ if has . $trustedTaps }}, trusted: true{{ end }}
{{ end -}}
{{ range $formulae | sortAlpha | uniq -}}
brew {{ quote . }}{{ if contains "/" . }}, trusted: true{{ end }}{{ if has . $services }}, restart_service: :changed{{ end }}
{{ end -}}
{{ range $c := (concat $casks $noShaCasks) | sortAlpha | uniq -}}
cask {{ quote $c }}{{ if not (has $c $noShaCasks) }}, args: { require_sha: true }{{ end }}{{ if contains "/" $c }}, trusted: true{{ end }}
{{ end -}}
{{ range .packages.macos.app_store -}}
mas {{ quote .name }}, id: {{ .id }}
{{ end -}}
