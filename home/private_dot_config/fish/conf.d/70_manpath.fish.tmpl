# empty entry: man derives from $PATH
set -q MANPATH; or set -x MANPATH ''

{{- if eq .chezmoi.os "darwin" }}
# info has no $PATH auto-derivation, so brew's infodir must be added
set -x INFOPATH $HOMEBREW_PREFIX/share/info ''
{{- end }}

# rust: cargo/rustc are rustup proxies; so we can't discover them implicitly
if test -e $XDG_DATA_HOME/rustup/toolchains
  set -l tc '' # empty -> $tc* is just *, matching every installed toolchain
  set -q RUSTUP_TOOLCHAIN[1]; and set tc $RUSTUP_TOOLCHAIN
  for man in (path filter -d $XDG_DATA_HOME/rustup/toolchains/$tc*/share/man)
    contains -- $man $MANPATH; or set -p MANPATH $man
  end
end
