#
# migration
#

# fish 4.3: key bindings are global by default. Erase any leftover universal
# (which fish <4.3 event handlers would otherwise re-create).
set -e -U fish_key_bindings
set -g fish_key_bindings fish_default_key_bindings

# fish_prefs: this file used to set universals and keep a list of what had been
# set; erase any remnants of that system.
if set -q fish_prefs_hash
  for pref in $fish_prefs
    set -e -U $pref
  end
  set -e -U fish_prefs fish_prefs_hash
end

#
# toolchains
#

# go
set -gx GOPATH $XDG_DATA_HOME/go
set -gx GOMODCACHE $XDG_CACHE_HOME/go/mod
set -gx GOCACHE $XDG_CACHE_HOME/go/build

# node
set -gx NODE_REPL_HISTORY $XDG_STATE_HOME/node/repl_history
set -gx NPM_CONFIG_USERCONFIG $XDG_CONFIG_HOME/npm/npmrc

# python
set -gx PYLINTHOME $XDG_CACHE_HOME/pylint
set -gx PYTHONSTARTUP $XDG_CONFIG_HOME/python/startup.py
set -gx PYTHON_HISTORY $XDG_STATE_HOME/python/history

# ruby
set -gx GEM_SPEC_CACHE $XDG_CACHE_HOME/gem
set -gx BUNDLE_USER_CONFIG $XDG_CONFIG_HOME/bundle
set -gx BUNDLE_USER_CACHE $XDG_CACHE_HOME/bundle
set -gx BUNDLE_USER_PLUGIN $XDG_DATA_HOME/bundle

# rust
set -gx RUSTUP_HOME $XDG_DATA_HOME/rustup
set -gx CARGO_HOME $XDG_DATA_HOME/cargo

#
# defaults
#

# core
set -gx EDITOR nvim
set -gx VISUAL nvim
set -gx PAGER less

#
# tools
#

# bash
set -gx HISTFILE $XDG_STATE_HOME/bash/history

# bd
set -g BD_OPT insensitive

# fish
set -g fish_greeting ''
set -g fish_term24bit 1

# fzf
set -g FZF_DEFAULT_OPTS_BASE \
  --ansi --no-bold \
  --marker='*' \
  --cycle \
  --layout=reverse --preview-window=wrap \
  --bind "'ctrl-\:toggle-preview'" \
  --bind "'ctrl-x:execute-silent(echo {+} | clipboard-provider copy)'"
set -gx FZF_DEFAULT_COMMAND 'fd --type=file --type=directory --hidden --strip-cwd-prefix --color=always .'

# fzf.fish
set -g fzf_fd_opts --hidden
set -g fzf_diff_highlighter delta --paging=never
{{ if lookPath "eza" -}}
set -g fzf_preview_dir_cmd eza --classify --git --group --all --color=always
{{ end -}}
# alt-d / alt-a reload the picker to dirs-only / all (files+dirs); the fd flags
# mirror $fzf_fd_opts (a fish var won't expand inside fzf's --bind at runtime).
set -g fzf_directory_opts \
  --scheme=path \
  --bind 'ctrl-v:execute(command nvim {} >/dev/tty)' \
  --bind 'alt-d:reload(fd --hidden --color=always --type=directory)' \
  --bind 'alt-a:reload(fd --hidden --color=always)'
set -g fzf_git_log_format '{{ .git.pretty.onelineplus }}'
set -g fzf_git_log_opts \
  --bind 'ctrl-o:execute-silent(git switch -d {})'
set -g fzf_git_status_opts --header-lines=1 # git config status.branch
set -g fzf_history_opts --nth=4..

# gdb
set -gx GDBHISTFILE $XDG_STATE_HOME/gdb/history

# homebrew
if is_macos
  set -gx HOMEBREW_AUTO_UPDATE_SECS 86400
  set -gx HOMEBREW_BAT 1
  set -gx HOMEBREW_CLEANUP_MAX_AGE_DAYS 30
  set -gx HOMEBREW_CLEANUP_PERIODIC_FULL_DAYS 7
  set -gx HOMEBREW_DEVELOPER 1
  set -gx HOMEBREW_NO_ANALYTICS 1
  set -gx HOMEBREW_NO_ENV_HINTS 1
  set -gx HOMEBREW_NO_INSECURE_REDIRECT 1
  set -gx HOMEBREW_REQUIRE_TAP_TRUST 1
  set -gx HOMEBREW_UPDATE_TO_TAG 1
  set -gx HOMEBREW_UPGRADE_GREEDY_CASKS 1
  set -gx HOMEBREW_VERIFY_ATTESTATIONS 1
end

# kubernetes
set -gx KUBECONFIG $XDG_CONFIG_HOME/kube/config
set -gx KUBECACHEDIR $XDG_CACHE_HOME/kube

# less
set -gx LESS '--mouse --tabs=2 --RAW-CONTROL-CHARS'
set -gx LESSHISTFILE $XDG_STATE_HOME/less/history

# pip
set -gx PIP_REQUIRE_VIRTUALENV 1

# postgres
set -gx PSQLRC $XDG_CONFIG_HOME/pg/psqlrc
set -gx PSQL_HISTORY $XDG_STATE_HOME/psql/history
set -gx PGPASSFILE $XDG_CONFIG_HOME/pg/pgpass
set -gx PGSERVICEFILE $XDG_CONFIG_HOME/pg/pg_service.conf

# readline
set -gx INPUTRC $XDG_CONFIG_HOME/readline/inputrc

# lsof
set -gx LSOFDEVCACHE $XDG_CACHE_HOME/lsof

# mysql
set -gx MYSQL_HISTFILE $XDG_STATE_HOME/mysql/history

# redis
set -gx REDISCLI_HISTFILE $XDG_STATE_HOME/rediscli/history

# ripgrep
set -gx RIPGREP_CONFIG_PATH $XDG_CONFIG_HOME/ripgrep/config

# shiv
set -gx SHIV_ROOT $XDG_CACHE_HOME/shiv

# sqlite
set -gx SQLITE_HISTORY $XDG_STATE_HOME/sqlite/history

# systemd
set -gx SYSTEMD_LESS '-FRSXMK --mouse --tabs=2'

# tmux
set -gx TMUX_TMPDIR $XDG_RUNTIME_DIR

# wget
set -gx WGETRC $XDG_CONFIG_HOME/wget/wgetrc

# vagrant
set -gx VAGRANT_HOME $XDG_DATA_HOME/vagrant
